# Google AI Studio API Key (Required)
# Get yours here: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# Discord or Slack Webhook URL (Optional)
# If provided, the send_notification tool will post the curated events here.
# WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# Automated Email Notifications via Gmail (Optional)
# SENDER_EMAIL=your_email@gmail.com
# RECEIVER_EMAIL=recipient_email@example.com
# EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx  # Google App Password if using Gmail SMTP
